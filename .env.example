# Copy to .env and fill in values. Do not commit .env.
# Load before running:  set -a && source .env && set +a
# (bash/zsh)  or use your shell or a secrets manager.

# Required: ElevenLabs API key (either name is accepted by export_conversations.py)
ELEVENLABS_API_KEY=

# Optional: use this instead of ELEVENLABS_API_KEY if you prefer
# XI_API_KEY=

# Optional: override API host (default https://api.elevenlabs.io)
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io
